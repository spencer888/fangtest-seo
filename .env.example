# ============================================================
# Шаблон конфигурации — скопируйте в .env и заполните
# ============================================================

# Telegram Bot
TG_TOKEN="your_telegram_bot_token"
TG_CHAT="your_telegram_chat_id"

# WordPress
WP_AUTH="Basic base64(username:app_password)"
WP_URL="http://localhost"

# OpenRouter API
OPENROUTER_KEY="sk-or-v1-..."
OPENROUTER_KEY_WORKFLOW="sk-or-v1-..."

# Пути
LOG_DIR="/home/user/.openfang/data"
OF_BIN="/home/user/.openfang/bin/openfang"
